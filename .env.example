# C++算法学习平台 环境配置
# 复制此文件为 .env 并填写你的API密钥

# LLM提供商选择: deepseek, openai, custom
LLM_PROVIDER=deepseek

# API密钥 (DeepSeek: https://platform.deepseek.com)
LLM_API_KEY=sk-da245599e4444489b0127424448551b4

# API地址
# DeepSeek: https://api.deepseek.com
# OpenAI: https://api.openai.com
# 其他兼容接口按需填写
LLM_API_BASE=https://api.deepseek.com

# 模型名称
LLM_MODEL=deepseek-v4-pro

# 服务端口
HOST=0.0.0.0
PORT=8000

# 数据库(默认SQLite,无需修改)
DATABASE_URL=sqlite:///./learning_platform.db
